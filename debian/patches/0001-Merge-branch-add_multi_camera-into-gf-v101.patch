+void CalibrateTouchDevice::calibration()
+{
+    if(!initXparam()) {
+        SYS_LOG(LOG_DEBUG,"open xorg error!");
+        return;
+    }
+
+    QString configPath = QString("/var/lib/lightdm-data/%1/usd/config/%2").arg(m_userName).arg(QString::fromLatin1(MAP_CONFIG));
+    QFileInfo file(configPath);
+
+    m_touchSceenMap = getAllTouchScreens();
+    m_outputMap = getAllOutput();
+
+    if(file.exists()) {
+        m_mapRelationList = getMapInfoListFromConfig(configPath);
+        calibrateTouchDeviceWithConfigFile(configPath);
+    } else {
+        USD_LOG(LOG_DEBUG,"can't find %s",configPath.toLatin1().data());
+    }
+    calibrateTouchScreen();
+//    exit(0);
+    Q_EMIT calibrateFinished();
+}
+
+int CalibrateTouchDevice::initXparam()
+{
+    int eventBase = 0;
+    int errorBase = 0;
+    int major = 0;
+    int minor = 0;
+
+    m_pDpy = XOpenDisplay (m_pDisplayName);
+    if (m_pDpy == NULL) {
+        SYS_LOG(LOG_DEBUG,"XOpenDisplay fail...");
+        return false;
+    }
+
+    if (!XRRQueryExtension (m_pDpy, &eventBase, &errorBase) ||
+            !XRRQueryVersion (m_pDpy, &major, &minor)) {
+        SYS_LOG(LOG_DEBUG, "RandR extension missing");
+        return false;
+    }
+
+    if (!(major >= 1 && minor >= 5)) {
+        SYS_LOG(LOG_DEBUG, "xrandr extension too low");
+    }
+
+    m_screen = DefaultScreen(m_pDpy);
+    if (m_screen >= ScreenCount (m_pDpy)) {
+        SYS_LOG(LOG_DEBUG,"Invalid screen number %d (display has %d)",m_screen, ScreenCount(m_pDpy));
+        return false;
+    }
+
+    m_rootWindow = RootWindow(m_pDpy, m_screen);
+
+    m_pScreenRes = XRRGetScreenResources(m_pDpy, m_rootWindow);
+    if (NULL == m_pScreenRes) {
+        SYS_LOG(LOG_DEBUG,"could not get screen resources",m_screen, ScreenCount(m_pDpy));
+        return false;
+    }
+
+    if (m_pScreenRes->noutput == 0) {
+        SYS_LOG(LOG_DEBUG, "noutput is 0!!");
+        return false;
+    }
+
+    SYS_LOG(LOG_DEBUG,"initXparam success");
+
+    for (int k = 0; k < m_pScreenRes->noutput; k++) {
+        USD_LOG(LOG_DEBUG,"k:%d --->%d",k, m_pScreenRes->outputs[k]);
+    }
+
+
+    for (int k = 0; k < m_pScreenRes->ncrtc; k++) {
+        USD_LOG(LOG_DEBUG,"crtc:%d --->%d",k, m_pScreenRes->crtcs[k]);
+    }
+
+    return true;
+}
+
+bool CalibrateTouchDevice::checkMatch(double opWidth,  double opHeight,double ipWidth, double ipHeight)
+{
+    double wdiff, hdiff;
+
+    wdiff = ABS(1 - (opWidth / ipWidth));
+    hdiff = ABS(1 - (opHeight / ipHeight));
+    USD_LOG(LOG_DEBUG,"w_diff--------%f,h_diff----------%f",wdiff,hdiff);
+
+    if (wdiff < MAX_SIZE_MATCH_DIFF && hdiff < MAX_SIZE_MATCH_DIFF) {
+        return true;
+    }
+    return false;
+}
+
+QList<CalibrateTouchDevice::MapInfoFromFile> CalibrateTouchDevice::getMapInfoListFromConfig(QString confPath)
+{
+    QList<CalibrateTouchDevice::MapInfoFromFile> mapRelationList;
+    QSettings *configIniRead = new QSettings(confPath, QSettings::IniFormat);
+
+    int mapNum = configIniRead->value("/COUNT/num").toInt();
+    if (mapNum < 1) {
+        configIniRead->deleteLater();
+        return mapRelationList;
+    }
+
+    for (int i = 0; i < mapNum ;++i) {
+        MapInfoFromFile mapRelation;
+        QString mapName = QString("/MAP%1/%2");
+        QString touchName = configIniRead->value(mapName.arg(i+1).arg("name")).toString();
+        QString scrname = configIniRead->value(mapName.arg(i+1).arg("scrname")).toString();
+        QString serial = configIniRead->value(mapName.arg(i+1).arg("serial")).toString();
+
+        if (NULL != touchName && NULL != scrname && NULL !=serial) {
+            mapRelation.sTouchName = touchName;
+            mapRelation.sMonitorName = scrname;
+            mapRelation.sTouchSerial = serial;
+            mapRelationList.append(mapRelation);
+        }
+    }
+
+    configIniRead->deleteLater();
+    return mapRelationList;
+}
+
+bool CalibrateTouchDevice::isTouchDevice(XIDeviceInfo dev)
+{
+    int i = 0;
+    if (dev.use != XISlavePointer) {
+        return false;
+    }
+
+    if (!dev.enabled) {
+        USD_LOG(LOG_DEBUG,"%s device is disabled.",dev.name);
+        return false;
+    }
+
+    QString devName = QString::fromUtf8(dev.name);
+    if (devName.toUpper().contains("TOUCHPAD")) {
+        return true;
+    }
+
+    for (int j = 0; j < dev.num_classes; j++) {
+        if (dev.classes[j]->type == XIValuatorClass) {
+            XIValuatorClassInfo *t = (XIValuatorClassInfo*)dev.classes[j];
+            // 如果当前的设备是绝对坐标映射 则认为该设备需要进行一次屏幕映射
+
+            if (t->mode == XIModeAbsolute) {
+                USD_LOG(LOG_DEBUG,"%s type:%d mode:%d", dev.name, dev.classes[i]->type, t->mode);
+                return true;
+            }
+        }
+    }
+    return false;
+}
+
+unsigned char *CalibrateTouchDevice::getDeviceNode (XIDeviceInfo devinfo)
+{
+    Atom  prop;
+    Atom act_type;
+    int  act_format;
+    unsigned long nitems, bytes_after;
+    unsigned char *data;
+
+    prop = XInternAtom(m_pDpy, XI_PROP_DEVICE_NODE, False);
+    if (!prop) {
+        return NULL;
+    }
+
+    if (XIGetProperty(m_pDpy, devinfo.deviceid, prop, 0, 1000, False,
+                      AnyPropertyType, &act_type, &act_format, &nitems, &bytes_after, &data) == Success) {
+        return data;//who use ,who free.
+    }
+    return NULL;
+}
+
+QMap<QString, int> CalibrateTouchDevice::getAllTouchScreens()
+{
+    int devicesNum;
+    XIDeviceInfo *devsInfo = nullptr;
+    QMap<QString, int> touchScreensList;
+
+    devsInfo = XIQueryDevice(m_pDpy, XIAllDevices, &devicesNum);
+
+    for (int i = 0; i < devicesNum; i ++) {
+        if (isTouchDevice(devsInfo[i])) {
+            unsigned char *node = getDeviceNode(devsInfo[i]);
+            if (node) {
+                touchScreensList.insert(QString::fromLatin1(devsInfo[i].name), devsInfo[i].deviceid);
+                XFree(node);
+            }
+        }
+    }
+
+    if (devsInfo != nullptr) {
+        XIFreeDeviceInfo(devsInfo);//TODO:test 是否需要释放。。？
+    }
+    return touchScreensList;
+}
+
+QMap<QString, int> CalibrateTouchDevice::getAllOutput()
+{
+    QMap<QString, int> outputMapList;
+    for (int koutput = 0; koutput < m_pScreenRes->noutput; koutput++) {
+        XRROutputInfo	*rrOutputInfo = XRRGetOutputInfo (m_pDpy, m_pScreenRes, m_pScreenRes->outputs[koutput]);
+        if (rrOutputInfo->connection != RR_Connected) {
+            XRRFreeOutputInfo(rrOutputInfo);
+            continue;
+        }
+        outputMapList.insert(QString::fromLatin1(rrOutputInfo->name), true);
+        XRRFreeOutputInfo(rrOutputInfo);
+    }
+    return outputMapList;
+}
+
+void CalibrateTouchDevice::calibrateTouchDeviceWithConfigFile(QString mapPath)
+{
+    for (int i = 0; i<m_mapRelationList.count(); ++i) {
+        int devId = m_touchSceenMap[m_mapRelationList[i].sTouchName];
+        int connected = m_outputMap[m_mapRelationList[i].sMonitorName];
+        if (connected && devId) {
+            calibrateDevice(devId, m_mapRelationList[i].sMonitorName);
+        }
+    }
+}
+
+void CalibrateTouchDevice::calibrateTouchScreen()
+{
+    int devicesNum;
+    GUdevDevice *udevDevice;
+    GUdevClient *udevClient;
+    XIDeviceInfo *devsInfo;
+    int missOutput = 0;
+    unsigned char *deviceFile;
+    const char *udevSubsystems[] = {"input", NULL};
+
+    devsInfo = XIQueryDevice(m_pDpy, XIAllDevices, &devicesNum);
+    udevClient = g_udev_client_new(udevSubsystems);
+
+    for (int koutput = 0; koutput < m_pScreenRes->noutput; koutput++) {
+        XRROutputInfo *outputInfo = XRRGetOutputInfo (m_pDpy, m_pScreenRes, m_pScreenRes->outputs[koutput]);
+        QString outputName = QString::fromLatin1(outputInfo->name);
+
+        if (m_outputHadMap[outputName] || outputInfo->connection != RR_Connected) {
+            USD_LOG(LOG_DEBUG,"[%s] map:[%d] connection:%d", outputName.toLatin1().data(), m_outputHadMap[outputName], outputInfo->connection);
+            XRRFreeOutputInfo(outputInfo);
+            continue;
+        }
+        missOutput++;
+        USD_LOG(LOG_DEBUG,"[%s] map:[%d] connection:%d", outputName.toLatin1().data(), m_outputHadMap[outputName], outputInfo->connection);
+
+
+        for (int i = 0; i < devicesNum; i ++) {
+            if (!isTouchDevice(devsInfo[i]) || m_touchSceenHadMap[devsInfo[i].deviceid] == 1) {
+                USD_LOG(LOG_DEBUG,"skip [%s] can't find ID_INPUT_TOUCHSCREEN or ID_INPUT_TABLET m_touchSceenHadMap[devsInfo[i].deviceid] = %d or is't touchDevice", devsInfo[i].name, m_touchSceenHadMap[devsInfo[i].deviceid]);
+                continue;
+            }
+
+            deviceFile = getDeviceNode(devsInfo[i]);
+            if (!deviceFile) {
+                USD_LOG(LOG_DEBUG,"skip [%s] can't get device node", devsInfo[i].name);
+                continue;
+            }
+
+            udevDevice = g_udev_client_query_by_device_file(udevClient,
+                                                             (const char *)deviceFile);
+
+            if (!((udevDevice && g_udev_device_has_property (udevDevice,
+                                                              "ID_INPUT_TOUCHSCREEN")) || g_udev_device_has_property(udevDevice,"ID_INPUT_TABLET"))) {
+//                USD_LOG(LOG_DEBUG,"skip [%s] can't find ID_INPUT_TOUCHSCREEN or ID_INPUT_TABLET", devsInfo[i].name);
+                XFree(deviceFile);
+                g_object_unref(udevDevice);
+                continue;
+            }
+
+           if (!g_udev_device_has_property (udevDevice,"ID_PATH")) {
+               XFree(deviceFile);
+               g_object_unref(udevDevice);
+//               USD_LOG(LOG_DEBUG,"skip [%s] can't find ID_PATH", devsInfo[i].name);
+               continue;
+           }
+
+           int width = g_udev_device_get_property_as_uint64 (udevDevice,
+                                                             "ID_INPUT_WIDTH_MM");
+           int height = g_udev_device_get_property_as_uint64 (udevDevice,
+                                                              "ID_INPUT_HEIGHT_MM");
+
+           if (!checkMatch(outputInfo->mm_width, outputInfo->mm_height, width, height)) {
+               XFree(deviceFile);
+               g_object_unref(udevDevice);
+               continue;
+           }
+
+           calibrateDevice(devsInfo[i].deviceid, outputName);
+           XFree(deviceFile);
+           g_object_unref(udevDevice);
+           missOutput--;
+           break;
+        }
+
+        XRRFreeOutputInfo(outputInfo);
+    }
+
+    if (1 == missOutput) {
+        for (int koutput = 0; koutput < m_pScreenRes->noutput; koutput++) {
+            XRROutputInfo *outputInfo = XRRGetOutputInfo (m_pDpy, m_pScreenRes, m_pScreenRes->outputs[koutput]);
+            QString outputName = QString::fromLatin1(outputInfo->name);
+
+            if (m_outputHadMap[outputName] || outputInfo->connection != RR_Connected) {
+                USD_LOG(LOG_DEBUG,"[%s] map:[%d] connection:%d", outputName.toLatin1().data(), m_outputHadMap[outputName], outputInfo->connection);
+                XRRFreeOutputInfo(outputInfo);
+                continue;
+            }
+
+            for (int i = 0; i < devicesNum; i ++) {
+                if (!isTouchDevice(devsInfo[i]) || m_touchSceenHadMap[devsInfo[i].deviceid]) {
+                    USD_LOG(LOG_DEBUG,"skip [%s] can't find ID_INPUT_TOUCHSCREEN or ID_INPUT_TABLET m_touchSceenHadMap[devsInfo[i].deviceid] = %d or is't touchDevice", devsInfo[i].name, m_touchSceenHadMap[devsInfo[i].deviceid]);
+                    continue;
+                }
+
+                deviceFile = getDeviceNode(devsInfo[i]);
+                if (!deviceFile) {
+                    USD_LOG(LOG_DEBUG,"skip [%s] can't get device node", devsInfo[i].name);
+                    continue;
+                }
+
+                udevDevice = g_udev_client_query_by_device_file(udevClient,
+                                                                 (const char *)deviceFile);
+
+                if (!((udevDevice && g_udev_device_has_property (udevDevice,
+                                                                  "ID_INPUT_TOUCHSCREEN")) || g_udev_device_has_property(udevDevice,"ID_INPUT_TABLET"))) {
+//                    USD_LOG(LOG_DEBUG,"skip [%s] can't find ID_INPUT_TOUCHSCREEN or ID_INPUT_TABLET", devsInfo[i].name);
+                    XFree(deviceFile);
+                    g_object_unref(udevDevice);
+                    continue;
+                }
+
+               if (!g_udev_device_has_property (udevDevice,"ID_PATH")) {
+                   g_object_unref(udevDevice);
+                   XFree(deviceFile);
+//                   USD_LOG(LOG_DEBUG,"skip [%s] can't find ID_PATH", devsInfo[i].name);
+                   continue;
+               }
+
+               int width = g_udev_device_get_property_as_uint64 (udevDevice,
+                                                                 "ID_INPUT_WIDTH_MM");
+               int height = g_udev_device_get_property_as_uint64 (udevDevice,
+                                                                  "ID_INPUT_HEIGHT_MM");
+               if (width > 0 && height >0) {
+                    calibrateDevice(devsInfo[i].deviceid, outputName);
+               }
+               g_object_unref(udevDevice);
+               break;
+            }
+        }
+    }
+    g_object_unref(udevClient);
+    XIFreeDeviceInfo(devsInfo);
+}
+
+void CalibrateTouchDevice::calibrateDevice(int touchDeviceID, QString outputName, bool isRemapFromFile)
+{
+    m_outputHadMap.insert(outputName, 1);
+    m_touchSceenHadMap.insert(touchDeviceID, 1);
+
+    QString buff = QString("xinput --map-to-output \"%1\" \"%2\"").arg(touchDeviceID).arg(outputName);
+    USD_LOG(LOG_DEBUG,"map touch-screen [%s]\n", buff.toLatin1().data());
+    QProcess::execute(buff);
+}
