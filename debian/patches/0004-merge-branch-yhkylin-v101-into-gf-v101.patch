+GmWorkThread::GmWorkThread(QObject *parent)
+{
+    m_rtTemperature = COLOR_TEMPERATURE_DEFAULT;
+    m_lastTemperature = COLOR_TEMPERATURE_DEFAULT;
+    m_targetTemp = COLOR_TEMPERATURE_DEFAULT;
+    m_pSetTimer = new QTimer(this);
