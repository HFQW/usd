+void XrandrManager::touchHotPlugSlot(bool action)
+{
+    static bool isRunning = false;
+    USD_LOG(LOG_DEBUG,"---- touch hot plug:%d ----",action);
+    if(action) {
+        if(!isRunning) {
+	    isRunning = true;
+	    QTimer::singleShot(350,this,[=]() {
+	        USD_LOG(LOG_DEBUG,"need to calibrate touch device ? try it");
+		calibrateTouchDevice();
+		isRunning = false;
+            });
+	}    
+    }
+}
 
