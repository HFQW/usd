+void MouseManager::SetMouseWheelSpeedByLibinput(XDeviceInfo *device_info)
+{
+    XDevice *device;
+    Atom prop;
+    Atom type;
+    Atom float_type;
+    int format, rc;
+    unsigned long nitems, bytes_after;
+
+    Display * dpy = QX11Info::display();
+    union {
+        unsigned char *c;
+        long *l;
+    } data;
+
+    float_type = property_from_name ("FLOAT");
+    if (!float_type) {
+        USD_LOG(LOG_WARNING,"property name to atom is failed");
+        return;
+    }
+
+    prop = property_from_name ("libinput Button Scrolling Speed");
+    if (!prop) {
+        USD_LOG(LOG_WARNING,"property name to atom is failed");
+        return;
+    }
+    try {
+        device = XOpenDevice (dpy, device_info->id);
+        if (device == NULL) {
+            USD_LOG(LOG_WARNING,"error : xopen device is failed");
+            return;
+        }
+        float speed = settings_mouse->get(KEY_MOUSE_WHEEL_SPEED).toFloat();
+        USD_LOG(LOG_DEBUG,"set mouse speed %f",speed);
+        rc = XGetDeviceProperty (dpy,device, prop, 0, 1, False, float_type, &type,
+                                 &format, &nitems, &bytes_after, &data.c);
+
+        if (rc == Success && type == float_type && format == 32 && nitems >= 1) {
+                *(float *) data.l = speed;
+                XChangeDeviceProperty (dpy, device, prop, float_type, 32,
+                                       PropModeReplace, data.c, nitems);
+        }
+        if (rc == Success) {
+                XFree (data.c);
+        }
+        XCloseDevice (dpy, device);
+
+    } catch (int x) {
+        USD_LOG(LOG_ERR,"catch a bug...");
+        return;
+    }
+}
+
+void MouseManager::SetMouseWheelSpeed(XDeviceInfo *device_info)
+{
+    if (query_device_had_property(device_info, "libinput Button Scrolling Speed")) {
+        QProcess::startDetached("imwheel -kq");
+        m_findScrollSpeed = true;
+        SetMouseWheelSpeedByLibinput(device_info);
+    } else if(!m_findScrollSpeed) {
+        SetMouseWheelSpeedByImwheel(settings_mouse->get(KEY_MOUSE_WHEEL_SPEED).toInt());
+    }
+}
+
+void MouseManager::SetMouseWheelSpeedAll()
+{
+    XDeviceInfo *device_info = nullptr;
+    int n_devices;
+    device_info = XListInputDevices (gdk_x11_get_default_xdisplay (), &n_devices);
+    if(!device_info){
+        qWarning("SetMotionAll: device_info is null");
+        return;
+    }
+    m_findScrollSpeed = false;
+    for (int i = 0; i < n_devices; i++) {
+        if (device_is_mouse(&device_info[i])) {
+            SetMouseWheelSpeed(&device_info[i]);
+        }
+    }
+    if (!device_info) {
+        XFreeDeviceList (device_info);
+    }
+}
